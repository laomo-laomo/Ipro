function normalizeStoryTitle(title: string): string {
  return title.replace(/[銆娿€?鈥溾€漒s]/g, '').trim();
}

function resolveClassicStory(title: string): { canonicalTitle: string; scenes: Scene[] } | null {
  const normalized = normalizeStoryTitle(title);
  for (const [key, value] of Object.entries(CLASSIC_STORY_LIBRARY)) {
    if (normalizeStoryTitle(key) === normalized || normalizeStoryTitle(value.canonicalTitle) === normalized) {
      return value;
    }
  }
  return null;
}

function isClassicStoryTitle(title: string): boolean {
  return resolveClassicStory(title) !== null;
}

function buildFallbackTemplate(title: string): { content: string; scenes: Scene[] } {
  const classicStory = resolveClassicStory(title);
  if (classicStory) {
    return {
      content: classicStory.scenes.map((scene) => scene.text).join('\n\n'),
      scenes: classicStory.scenes,
    };
  }

  const normalizedTitle = title.trim();
  const scenes: Scene[] = [
    { index: 0, description: `${normalizedTitle}鐨勪富瑙掑湪娓╂殩娓呮櫒鍑哄彂锛屽績閲屽甫鐫€鏈熷緟涓庝竴鐐圭偣绱у紶`, text: `娓呮櫒锛?{normalizedTitle}鐨勪富瑙掔珯鍦ㄧ獥鍓嶏紝鏈涚潃鍒氬垰浜捣鏉ョ殑澶╃┖锛屽績閲岃鐫€涓€涓噸瑕佺殑鐩爣銆俆A鐭ラ亾锛岃繖涓€澶╀笉浼氬儚骞冲父閭ｆ牱绠€鍗曪紝浣嗕篃姝ｅ洜涓哄姝わ紝杩欒稛鏃呯▼鎵嶆樉寰楁牸澶栫壒鍒€俙 },
    { index: 1, description: `鏃呴€斾腑锛屼富瑙掗亣鍒颁簡鏂扮殑浼欎即鍜屾剰鏂欎箣澶栫殑闅鹃锛屽懆鍥存櫙璞″厖婊″彉鍖朻, text: `鍑哄彂娌″涔咃紝涓昏灏遍亣瑙佷簡涓€浣嶉渶瑕佸府鍔╃殑鏂版湅鍙嬨€備笌姝ゅ悓鏃讹紝涓€閬撴剰鏂欎箣澶栫殑闅鹃涔熸倓鎮勫嚭鐜板湪鐪煎墠銆備富瑙掓病鏈夋€ョ潃鎶辨€紝鑰屾槸鍋滀笅鏉ヨ鐪熻瀵燂紝鍔姏寮勬槑鐧戒簨鎯呯湡姝ｅ洶闅剧殑鍦版柟銆俙 },
    { index: 2, description: `涓昏鍜屼紮浼翠竴璧峰皾璇曡В鍐抽棶棰橈紝杩囩▼涓湁澶辫触銆佹湁鐘硅鲍锛屼絾涔熸湁鏂扮殑鍙戠幇`, text: `鎺ヤ笅鏉ョ殑璺苟涓嶉『鍒┿€備富瑙掑拰浼欎即璇曚簡涓€涓姙娉曪紝鍙堟崲浜嗗彟涓€涓姙娉曪紝涓棿涔熼亣鍒拌繃澶辫鍜岀姽璞€傚彲姣忎竴娆″仠涓嬫潵閲嶆柊鎬濊€冿紝涓昏閮借兘浠庡け璐ラ噷鎵惧埌鏂扮殑绾跨储锛屼篃鎱㈡參瀛︿細浜嗘洿鑰愬績銆佹洿鍕囨暍鍦伴潰瀵规寫鎴樸€俙 },
    { index: 3, description: `鏁呬簨杩涘叆杞姌锛屼富瑙掔粓浜庣湅娓呴棶棰樻牳蹇冿紝骞朵綔鍑洪噸瑕侀€夋嫨`, text: `灏卞湪浜嬫儏鏈€璁╀汉鐫€鎬ョ殑鏃跺€欙紝涓昏蹇界劧鏄庣櫧浜嗛棶棰樼殑鍏抽敭銆傜湡姝ｉ渶瑕佹敼鍙樼殑锛屼笉鍙槸鐪煎墠鐨勫眬闈紝杩樻湁鑷繁闈㈠鍥伴毦鏃剁殑鏂瑰紡銆備簬鏄紝TA鍋氬嚭浜嗕竴涓噸瑕佸喅瀹氾紝涔熻鍛ㄥ洿鐨勪竴鍒囧紑濮嬫倓鎮勬湞鐫€鏇村ソ鐨勬柟鍚戣浆鍔ㄣ€俙 },
    { index: 4, description: `澶曢槼涓嬶紝浜嬫儏鍦嗘弧瑙ｅ喅锛屼富瑙掑拰浼欎即鍒嗕韩鎴愭灉锛屼篃鏀惰幏浜嗘垚闀縛, text: `鍒颁簡鍌嶆櫄锛屾墍鏈夊姫鍔涚粓浜庢湁浜嗘俯鏆栫殑缁撴灉銆備富瑙掑拰浼欎即涓€璧风湅鐫€浜嬫儏琚『鍒╄В鍐筹紝蹇冮噷鍏呮弧浜嗚交鏉惧拰鍠滄偊銆俆A涔熺涓€娆＄湡姝ｆ槑鐧斤紝鎴愰暱骞朵笉鏄竴涓嬪瓙鍙樺緱浜嗕笉璧凤紝鑰屾槸鍦ㄦ瘡涓€娆¤鐪熷皾璇曘€佹瘡涓€娆℃効鎰忓府鍔╁埆浜烘椂锛屾參鎱㈠彉鎴愭洿濂界殑鑷繁銆俙 },
  ];

  return {
    content: scenes.map((scene) => scene.text).join('\n\n'),
    scenes,
  };
}
function parseScenes(raw: string | null | undefined): Scene[] {
  if (!raw) {
    return [];
  }

  try {
    const parsed = JSON.parse(raw);
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

function toSceneArray(input: any[]): Scene[] {
  return input.map((item, index) => ({
    index: typeof item?.index === 'number' ? item.index : index,
    description: item?.description || item?.sceneDesc || item?.title || `绗?${index + 1} 骞昤,
    text: item?.text || item?.content || '',
  }));
}

function parseSegmentIndex(segmentId: string): number | null {
  const exactNumber = Number(segmentId);
  if (Number.isInteger(exactNumber) && exactNumber >= 0) {
    return exactNumber;
  }

  const match = segmentId.match(/(\d+)$/);
  if (!match) {
    return null;
  }

  const index = Number(match[1]);
  return Number.isInteger(index) && index >= 0 ? index : null;
}

async function getCharacterDescription(
  fastify: FastifyInstance,
  characterId: string
): Promise<string> {
  const character = await fastify.prisma.character.findUnique({
    where: { id: characterId },
  });

  if (!character) {
    return '涓€涓彲鐖辩殑灏忔湅鍙?;
  }

  if (character.featureDesc) {
    return character.featureDesc;
  }

  if (character.stylizedPhotoUrl) {
    return '涓€涓互鎻掔敾褰㈣薄涓轰富瑙?;
  }

  return '涓€涓彲鐖辩殑灏忔湅鍙?;
}

function storyResponse(story: any) {
  return {
    ...story,
    scenes: parseScenes(story.scenes),
  };
}

export async function storyRoutes(fastify: FastifyInstance) {
  fastify.get('/templates', async (_request: FastifyRequest, reply: FastifyReply) => {
    try {
      const templates = await fastify.prisma.storyTemplate.findMany({
        where: { status: 'active' },
        select: {
          id: true,
          title: true,
          cover: true,
          scenes: true,
        },
        orderBy: { createdAt: 'asc' },
      });

      const result = templates.map((template) => ({
        id: template.id,
        title: template.title,
        cover: template.cover,
        sceneCount: parseScenes(template.scenes).length,
      }));

      return {
        success: true,
        data: result,
      };
    } catch (error) {
      fastify.log.error(error);
      return reply.status(500).send({
        success: false,
        message: 'Failed to fetch templates',
      });
    }
  });

  fastify.post<{ Body: CreateBody }>('/create', async (request, reply) => {
    const userId = request.user?.id;
    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const parseResult = createSchema.safeParse(request.body);
    if (!parseResult.success) {
      return reply.status(400).send({
        success: false,
        message: 'Invalid request body',
        errors: parseResult.error.errors,
      });
    }

    const { characterId, templateId, templateName, source: _source } = parseResult.data;

    const character = await fastify.prisma.character.findFirst({
      where: { id: characterId, userId },
    });

    if (!character) {
      return reply.status(404).send({ success: false, message: 'Character not found' });
    }

    try {
      let title = parseResult.data.title || parseResult.data.customTitle || '';

      if (!title && templateId) {
        const template = await fastify.prisma.storyTemplate.findUnique({
          where: { id: templateId },
        });

        title = template?.title || templateName || templateId;
      }

      const characterDesc = await getCharacterDescription(fastify, characterId);
      const source = templateId ? 'template' : 'custom';

      let storyData: { content: string; scenes: Scene[] };
      try {
        storyData = isClassicStoryTitle(title) ? buildFallbackTemplate(title) : await generateStoryWithAI(title, characterDesc);
      } catch (error) {
        fastify.log.warn({ error: error instanceof Error ? error.message : error, title, templateId, classic: isClassicStoryTitle(title) }, '[Story] Unified AI generation failed, using fallback story');
        storyData = buildFallbackTemplate(title);
      }

      const story = await fastify.prisma.story.create({
        data: {
          userId,
          characterId,
          title,
          content: storyData.content,
          scenes: JSON.stringify(storyData.scenes),
          source,
          status: 'draft',
        },
      });

      return {
        success: true,
        data: {
          storyId: story.id,
          title: story.title,
          content: story.content,
          scenes: parseScenes(story.scenes),
          status: story.status,
        },
      };
    } catch (error) {
      fastify.log.error(error);
      return reply.status(500).send({ success: false, message: 'Failed to create story' });
    }
  });
  fastify.post<{ Body: GenerateBody }>('/generate', async (request, reply) => {
    const userId = request.user?.id;
    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const parseResult = generateSchema.safeParse(request.body);
    if (!parseResult.success) {
      return reply.status(400).send({
        success: false,
        message: 'Invalid request body',
        errors: parseResult.error.errors,
      });
    }

    const { characterId } = parseResult.data;
    const title = parseResult.data.title || parseResult.data.customTitle!;

    const character = await fastify.prisma.character.findFirst({
      where: { id: characterId, userId },
    });

    if (!character) {
      return reply.status(404).send({ success: false, message: 'Character not found' });
    }

    try {
      const characterDesc = await getCharacterDescription(fastify, characterId);

      let storyData: { content: string; scenes: Scene[] };
      try {
        storyData = isClassicStoryTitle(title) ? buildFallbackTemplate(title) : await generateStoryWithAI(title, characterDesc);
      } catch (error) {
        fastify.log.warn({ error: error instanceof Error ? error.message : error, title, classic: isClassicStoryTitle(title) }, '[Story] AI generation failed, using fallback story');
        storyData = buildFallbackTemplate(title);
      }

      const story = await fastify.prisma.story.create({
        data: {
          userId,
          characterId,
          title,
          content: storyData.content,
          scenes: JSON.stringify(storyData.scenes),
          source: 'custom',
          status: 'draft',
        },
      });

      return {
        success: true,
        data: {
          storyId: story.id,
          title: story.title,
          content: story.content,
          scenes: parseScenes(story.scenes),
          status: story.status,
        },
      };
    } catch (error) {
      fastify.log.error(error);
      return reply.status(500).send({ success: false, message: 'Failed to generate story' });
    }
  });

  fastify.post<{ Body: FromTemplateBody }>('/from-template', async (request, reply) => {
    const userId = request.user?.id;
    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const parseResult = fromTemplateSchema.safeParse(request.body);
    if (!parseResult.success) {
      return reply.status(400).send({
        success: false,
        message: 'Invalid request body',
        errors: parseResult.error.errors,
      });
    }

    const { templateId, templateName, characterId } = parseResult.data;

    const character = await fastify.prisma.character.findFirst({
      where: { id: characterId, userId },
    });

    if (!character) {
      return reply.status(404).send({ success: false, message: 'Character not found' });
    }

    try {
      const template = await fastify.prisma.storyTemplate.findUnique({
        where: { id: templateId },
      });

      const title = template?.title || templateName || templateId;
      const characterDesc = await getCharacterDescription(fastify, characterId);

      let storyData: { content: string; scenes: Scene[] };
      try {
        storyData = isClassicStoryTitle(title) ? buildFallbackTemplate(title) : await generateStoryWithAI(title, characterDesc);
      } catch (error) {
        fastify.log.warn({ error: error instanceof Error ? error.message : error, title, templateId, classic: isClassicStoryTitle(title) }, '[Story] Template AI generation failed, using fallback story');
        storyData = buildFallbackTemplate(title);
      }

      const story = await fastify.prisma.story.create({
        data: {
          userId,
          characterId,
          title,
          content: storyData.content,
          scenes: JSON.stringify(storyData.scenes),
          source: 'template',
          status: 'draft',
        },
      });

      return {
        success: true,
        data: {
          storyId: story.id,
          title: story.title,
          content: story.content,
          scenes: parseScenes(story.scenes),
          status: story.status,
        },
      };
    } catch (error) {
      fastify.log.error(error);
      return reply.status(500).send({ success: false, message: 'Failed to create story from template' });
    }
  });

  fastify.get('/', async (request: FastifyRequest, reply: FastifyReply) => {
    const userId = request.user?.id;
    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const stories = await fastify.prisma.story.findMany({
      where: { userId },
      include: {
        illustrations: { orderBy: { sceneIndex: 'asc' } },
        videos: { orderBy: { createdAt: 'desc' }, take: 1 },
      },
      orderBy: { createdAt: 'desc' },
    });

    return {
      success: true,
      data: stories.map(storyResponse),
    };
  });

  fastify.get<{ Params: StoryParams }>('/:id', async (request, reply) => {
    const userId = request.user?.id;
    const { id } = request.params;

    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const story = await fastify.prisma.story.findFirst({
      where: { id, userId },
      include: { illustrations: { orderBy: { sceneIndex: 'asc' } } },
    });

    if (!story) {
      return reply.status(404).send({ success: false, message: 'Story not found' });
    }

    return {
      success: true,
      data: {
        ...story,
        scenes: parseScenes(story.scenes),
        illustrations: story.illustrations,
      },
    };
  });

  fastify.get<{ Params: StoryParams }>('/:id/progress', async (request, reply) => {
    const userId = request.user?.id;
    const { id } = request.params;

    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const story = await fastify.prisma.story.findFirst({
      where: { id, userId },
      include: {
        illustrations: true,
        videos: true,
      },
    });

    if (!story) {
      return reply.status(404).send({ success: false, message: 'Story not found' });
    }

    const totalIllustrations = story.illustrations.length;
    const completedIllustrations = story.illustrations.filter((item) => item.status === 'completed').length;
    const failedIllustrations = story.illustrations.filter((item) => item.status === 'failed').length;
    const latestVideo = story.videos[0];

    let currentStep = '鏁呬簨宸茬敓鎴?;
    let progress = 100;
    let status = story.status === 'processing' ? 'illustrating' : story.status;

    if (story.status === 'draft') {
      status = 'generating';
      currentStep = '姝ｅ湪鐢熸垚鏁呬簨';
      progress = 5;
    } else if (story.status === 'processing') {
      status = 'illustrating';
      currentStep = '姝ｅ湪鐢熸垚鎻掔敾';
      progress = totalIllustrations > 0 ? Math.round((completedIllustrations / totalIllustrations) * 100) : 10;
    } else if (latestVideo?.status === 'processing') {
      status = 'rendering';
      currentStep = '姝ｅ湪鐢熸垚瑙嗛';
      progress = 80;
    } else if (story.status === 'illustrated' || story.status === 'completed') {
      status = 'completed';
      currentStep = '宸插畬鎴?;
      progress = 100;
    }

    return {
      success: true,
      data: {
        storyId: story.id,
        status,
        currentStep,
        progress,
        completedIllustrations,
        failedIllustrations,
        totalIllustrations,
      },
    };
  });

  fastify.put<{ Params: StoryParams; Body: { segments: any[] } }>('/:id/segments', async (request, reply) => {
    const userId = request.user?.id;
    const { id } = request.params;

    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const story = await fastify.prisma.story.findFirst({
      where: { id, userId },
    });

    if (!story) {
      return reply.status(404).send({ success: false, message: 'Story not found' });
    }

    const segments = Array.isArray(request.body?.segments) ? request.body.segments : [];
    const scenes = toSceneArray(segments);

    const updatedStory = await fastify.prisma.story.update({
      where: { id },
      data: {
        scenes: JSON.stringify(scenes),
        content: scenes.map((scene) => scene.text).join('\n\n'),
      },
      include: {
        illustrations: { orderBy: { sceneIndex: 'asc' } },
      },
    });

    return {
      success: true,
      data: storyResponse(updatedStory),
    };
  });

  fastify.patch<{ Params: SegmentParams; Body: SegmentPatchBody }>('/:id/segments/:segmentId', async (request, reply) => {
    const userId = request.user?.id;
    const { id, segmentId } = request.params;

    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const story = await fastify.prisma.story.findFirst({
      where: { id, userId },
    });

    if (!story) {
      return reply.status(404).send({ success: false, message: 'Story not found' });
    }

    const targetIndex = parseSegmentIndex(segmentId);
    if (targetIndex === null) {
      return reply.status(400).send({ success: false, message: 'Invalid segment id' });
    }

    const scenes = parseScenes(story.scenes).map((scene) => {
      if (scene.index !== targetIndex) {
        return scene;
      }

      return {
        ...scene,
        description: request.body?.description || request.body?.sceneDesc || scene.description,
        text: request.body?.text || request.body?.content || scene.text,
      };
    });

    const updatedStory = await fastify.prisma.story.update({
      where: { id },
      data: {
        scenes: JSON.stringify(scenes),
        content: scenes.map((scene) => scene.text).join('\n\n'),
      },
      include: {
        illustrations: { orderBy: { sceneIndex: 'asc' } },
      },
    });

    return {
      success: true,
      data: storyResponse(updatedStory),
    };
  });

  fastify.put<{ Params: StoryParams; Body: UpdateStoryBody }>('/:id', async (request, reply) => {
    const userId = request.user?.id;
    const { id } = request.params;

    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const parseResult = updateStorySchema.safeParse(request.body);
    if (!parseResult.success) {
      return reply.status(400).send({
        success: false,
        message: 'Invalid request body',
        errors: parseResult.error.errors,
      });
    }

    const story = await fastify.prisma.story.findFirst({
      where: { id, userId },
    });

    if (!story) {
      return reply.status(404).send({ success: false, message: 'Story not found' });
    }

    const nextScenes = parseResult.data.scenes || parseScenes(story.scenes);

    const updatedStory = await fastify.prisma.story.update({
      where: { id },
      data: {
        content: parseResult.data.content ?? story.content,
        scenes: JSON.stringify(nextScenes),
      },
      include: {
        illustrations: { orderBy: { sceneIndex: 'asc' } },
      },
    });

    return {
      success: true,
      data: storyResponse(updatedStory),
    };
  });

  fastify.delete<{ Params: StoryParams }>('/:id', async (request, reply) => {
    const userId = request.user?.id;
    const { id } = request.params;

    if (!userId) {
      return reply.status(401).send({ success: false, message: 'Unauthorized' });
    }

    const story = await fastify.prisma.story.findFirst({
      where: { id, userId },
    });

    if (!story) {
      return reply.status(404).send({ success: false, message: 'Story not found' });
    }

    await fastify.prisma.story.delete({
      where: { id },
    });

    return {
      success: true,
      message: 'Story deleted',
    };
  });
}













