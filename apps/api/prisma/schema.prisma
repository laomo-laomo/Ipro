generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  openid      String?  @unique
  phone       String?  @unique
  nickname    String?
  avatar      String?
  role        String   @default("user")  // user, admin
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  characters  Character[]
  stories     Story[]
  voices      UserVoice[]
  memberships Membership[]
  orders      Order[]
  notifications PaymentNotification[]
  redeemCodes RedeemCode[] @relation("RedeemCodeUsedBy")
  customStyles CustomStyle[]
}

// User-defined character stylization prompts. Stores custom art-direction
// prompts that the AI service can pass through to apiz.ai when the user
// chooses a "Custom Style" in the style picker. Each row is owned by a single
// user and is referenced (by id) from the web StyleLibrary UI when the user
// clicks a custom tile.
model CustomStyle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Display name in the UI (1-30 chars).
  name        String
  // Full prompt the user wrote (1-2000 chars). Passed to apiz.ai as the
  // styleSuffix for stylizeCharacter when this style is selected.
  prompt      String
  // Tailwind color-theme key (orange, sky, emerald, rose, violet, amber,
  // cyan, lime). Drives the swatch / accent color in the StyleLibrary UI.
  colorTheme  String   @default("violet")
  // Lucide-react icon name for the tile.
  iconName    String   @default("Sparkles")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model UserVoice {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  audioUrl    String
  modelUrl    String?
  status      String    @default("processing") // processing, active, expired, failed
  progress    Int       @default(0) // 0-100 polling progress
  expiresAt   DateTime?
  pollingStartedAt DateTime? // when polling started
  pollingEndedAt   DateTime? // when polling ended
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([status])
}

model Character {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalPhotoUrl   String
  stylizedPhotoUrl   String?
  // Tracks the story title / context the current `stylizedPhotoUrl` was generated
  // for. Used to decide whether a story creation must trigger a re-stylize.
  lastStylizedTitle  String?
  lastStylizedAt     DateTime?
  featureDesc        String?
  // Hard identity fields extracted from the source photo by vision LLM.
  // These are STRUCTURAL constraints that the story generator / illustration
  // prompts must respect — unlike featureDesc (a free-text appearance blurb
  // the LLM is allowed to massage), these four columns pin down who the
  // protagonist must be so we no longer get "user uploaded a boy, story says
  // 小兔子朵朵" drift.
  //   gender       'male' | 'female' | 'unknown'
  //   ageBand      'child' | 'teen' | 'adult' | 'unknown'
  //   subjectKind  'human' | 'animal' (the user might have uploaded a pet)
  //   characterName optional display name (LLM can name the protagonist if blank)
  gender             String?
  ageBand            String?
  subjectKind        String?
  characterName      String?
  status             String   @default("pending") // pending, processing, completed
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model Story {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId String?
  title       String
  content     String
  cover       String?
  scenes      String   // JSON: [{index, description, text}]
  // Per-story costume reference. When a story is created with a title that
  // differs from the character's `lastStylizedTitle`, the system re-stylizes
  // the character and stores the result here. The illustration service
  // prefers this URL over the global `Character.stylizedPhotoUrl` so the
  // character's clothing matches the story (e.g. 卖火柴的小女孩 no longer
  // wears the Snow White ball gown).
  characterStylizedUrl String?
  source      String   @default("template") // template, custom
  status      String   @default("draft") // draft, processing, covering, illustrated, completed
  errorMessage String?
  totalCost   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  illustrations Illustration[]
  videos        Video[]
  sceneAudios   SceneAudio[]

  @@index([userId])
}

model Illustration {
  id               String   @id @default(cuid())
  storyId          String
  story            Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  sceneIndex       Int
  imageUrl         String?
  prompt           String?
  originalPrompt   String?
  errorMessage     String?
  failureCategory  String?
  retryCount       Int      @default(0)
  status           String   @default("pending") // pending, processing, completed, failed
  cost             Float    @default(0)
  createdAt        DateTime @default(now())
  // 修复 (2026-06-18 worker-recovery): 记录 worker 进程开始处理本 illustration 的时间.
  // 用于 rescueStuckIllustrations() 区分"正在跑"和"server 重启后没人接"两种状态:
  //   - status='processing' + workerStartedAt IS NULL → 老数据 / 重启前没记录, 直接重置
  //   - status='processing' + workerStartedAt > now - 3min → 当前进程正在跑, 跳过
  //   - status='processing' + workerStartedAt < now - 3min → 上一个 worker 死了, 重置 + 重新 enqueue
  workerStartedAt  DateTime?

  @@unique([storyId, sceneIndex])
  @@index([storyId])
}

model SceneAudio {
  id          String   @id @default(cuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  sceneIndex  Int
  audioUrl    String?
  text        String
  audioType   String   @default("tts") // tts, cloned
  voiceId     String?
  voiceName   String?
  voice       String?
  charCount   Int      @default(0)
  status      String   @default("pending") // pending, processing, completed, failed
  errorMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storyId, sceneIndex])
  @@index([storyId])
  @@index([status])
}

model Video {
  id          String   @id @default(cuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  videoUrl    String?
  audioUrl    String?  // Audio URL used for rendering
  audioType   String   @default("tts") // tts, cloned
  voiceId     String?
  charCount   Int      @default(0)
  cost        Float    @default(0)
  status      String   @default("pending") // pending, processing, completed, failed
  // Live progress (persisted so polling can recover when SSE dies / API restarts)
  progress    Int      @default(0)        // 0-100
  stage       String?                      // idle | audio_generating | audio_done | rendering | video_done | completed
  message     String?                      // optional human-readable status note
  errorMessage String?                     // populated when status=failed
  // Metadata after completion
  duration    Float?   // Duration in seconds
  resolution  String?  // e.g., "1920x1080"
  fileSize    Int?    // File size in bytes
  renderer    String  @default("ffmpeg") // ffmpeg | remotion
  createdAt   DateTime @default(now())

  @@index([storyId])
  @@index([status])
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardType    String   // weekly, monthly, quarterly, yearly
  quota       Int      @default(0)
  usedQuota   Int      @default(0)
  expiresAt   DateTime
  status      String   @default("active") // active, expired
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Order {
  id              String   @id @default(cuid())
  orderNo         String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // image, story, membership, voice_clone, video
  amount          Float
  status          String   @default("pending") // pending, paid, refunded, cancelled
  paymentChannel  String?  // wechat, alipay, stripe
  transactionId   String?
  metadata        String?  // JSON: 额外数据
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PriceConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Float
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model StoryTemplate {
  id          String   @id @default(cuid())
  title       String   @unique
  content     String
  scenes      String   // JSON: 预定义场景
  cover       String?
  status      String   @default("active") // active, disabled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PhoneCode {
  id          String   @id @default(cuid())
  phone       String
  code        String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model PaymentNotification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // payment_success, order_cancelled, membership_expired, etc.
  title       String
  content     String
  data        String?  // JSON: additional data
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model PaymentLog {
  id          String   @id @default(cuid())
  orderNo     String
  channel     String   // wechat, alipay, stripe
  event       String   // callback, webhook, etc.
  requestData String   // JSON: raw request data
  responseData String? // JSON: response sent
  status      String   // success, failed, error
  errorMessage String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([orderNo])
  @@index([channel])
  @@index([createdAt])
}

model RedeemCode {
  id            String   @id @default(cuid())
  code          String   @unique
  rewardType    String   // points, membership
  pointsAmount  Int?
  membershipTier String?
  expiresAt     DateTime?
  usedByUserId  String?
  usedByUser    User?    @relation("RedeemCodeUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)
  usedAt        DateTime?
  status        String   @default("active") // active, used, expired, disabled
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([rewardType])
  @@index([usedByUserId])
}
