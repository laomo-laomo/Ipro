# Ipro 环境变量配置

# ===========================================
# 通用
# ===========================================
NODE_ENV=development

# ===========================================
# 数据库
# ===========================================
DATABASE_URL=file:./dev.db

# ===========================================
# Redis
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# apiz.ai（ChatGPT Images 2.0）
# ===========================================
APIZ_API_KEY=sk-your-apiz-api-key

# ===========================================
# MiniMax (TTS + 声音克隆)
# ===========================================
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id

# ===========================================
# 腾讯云 COS
# ===========================================
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-cos-bucket
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=
# ===========================================
# 阿里云 OSS
# ===========================================
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=ipro
OSS_REGION=cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# ===========================================
# 微信登录（小程序 wx.login / code2Session）
# ===========================================
WECHAT_APP_ID=wx-your-mini-program-app-id
WECHAT_APP_SECRET=your-mini-program-app-secret
# miniapp = only use jscode2session; oauth = official-account OAuth; auto = miniapp first, then OAuth fallback
WECHAT_LOGIN_TYPE=miniapp

# ===========================================
# 微信支付
# ===========================================
WECHAT_MCH_ID=your-mch-id
WECHAT_API_KEY=your-api-key
WECHAT_NOTIFY_URL=http://localhost:3001/api/orders/callback/wechat

# ===========================================
# Stripe
# ===========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===========================================
# Apple IAP (P1-3 合规 2026-06-22)
# ===========================================
# 共享密钥: App Store Connect → 用户与访问 → 共享密钥 → 生成 App-Specific Shared Secret
APPLE_IAP_SHARED_SECRET=your-app-specific-shared-secret
# Bundle ID: 跟 Apple Developer 后台一致 (iOS 应用包名)
IOS_APP_BUNDLE_ID=com.iyinian.ipro
# RSA 私钥: 用于 wx.requestVirtualPayment 的 sign 字段签名
# 微信后台下载私钥后, 用 "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----" 格式填到一行 (注意 \n 转义)
# 留空时使用 HMAC 兜底 (仅 dev 可用, 生产 Apple 服务器会拒绝)
IAP_SIGN_PRIVATE_KEY=

# ===========================================
# JWT
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=http://localhost:3000

# ===========================================
# 支付配置（可后台调整）
# ===========================================
PRICE_IMAGE=0.2
PRICE_VOICE_CLONE=19.9
PRICE_CLONED_VOICE_PER_1K_CHAR=0.2
PRICE_WEEKLY_CARD=19.9
PRICE_MONTHLY_CARD=59
PRICE_QUARTERLY_CARD=159
PRICE_YEARLY_CARD=499

# ===========================================
# LLM Provider (story generation)
# ===========================================
# Supported providers: deepseek | qwen (阿里云) | openai | minimax
LLM_PROVIDER=deepseek

# DeepSeek API Key (recommended, cost-effective)
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# DeepSeek default model
# Options: deepseek-chat (V4-Flash) | deepseek-reasoner (R1)
LLM_DEFAULT_MODEL=deepseek-chat

# 阿里云 Qwen (fallback)
# QWEN_API_KEY=your-qwen-api-key

# OpenAI (fallback, only if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# MiniMax chat (fallback, only if LLM_PROVIDER=minimax)
MINIMAX_CHAT_API_KEY=your-minimax-chat-api-key
